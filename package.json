{
  "name": "voice-room-server",
  "version": "1.0.0",
  "description": "Voice Room SSE Test Server",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/app.ts",
    "dev:sqlite": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/app.js",
    "test": "DB_PATH=:memory: tsx --test tests/*.test.ts",
    "seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@scalar/express-api-reference": "^0.9.9",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.19.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.2",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@asyncapi/generator": "^2.11.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.0.0",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
